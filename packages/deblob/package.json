{
  "name": "deblob",
  "version": "0.0.1",
  "description": "Home of the deblob CLI — under construction. Machine-checkable hexagonal architecture for TypeScript/ESM.",
  "license": "MIT",
  "author": "rixo",
  "repository": {
    "type": "git",
    "url": "https://github.com/rixo/deblob"
  },
  "type": "module",
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "deblob": "./dist/drivers/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "README.md",
    "dist"
  ],
  "dependencies": {
    "@oxc-project/types": "0.140.0",
    "oxc-parser": "0.140.0",
    "oxc-resolver": "11.24.2",
    "picomatch": "^4.0.5",
    "tinyglobby": "^0.2.17"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "npm-run-all2": "^9.0.2",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "build": "run-s build:*",
    "build:content": "node scripts/build-content.ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "check": "node src/drivers/cli/bin.ts check",
    "prepack": "pnpm build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
